# ⚠️ 이 파일은 공개 템플릿입니다. 실제 값은 .env.local 에 넣으세요.
# .env.local 은 .gitignore 에 포함되며, Claude 는 이 파일을 읽지 않습니다.

# ---- SOLAPI (문자하랑) ----
# https://console.solapi.com  →  설정  →  API Key
SOLAPI_API_KEY=NCSxxxxxxxxxxxxxxxxxxxx
SOLAPI_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 테스트용 발신번호 (등록된 발신번호 중 하나)
SOLAPI_SENDER_EXAMPLE=01000000000

# 카카오 비즈 (알림톡/친구톡) 사용 시
# https://console.solapi.com → 카카오 → 채널 관리
SOLAPI_KAKAO_PFID=

# ---- Kakao Developers (앱 ID 714896) ----
# 필요 시 추가

# ---- Google Ads ----
# 나중에 채움

# ---- Meta Ads ----
# 나중에 채움

# ---- Supabase ----
# 나중에 채움
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
